# CFAI environment template (post-Module-1 cutover)
# Copy to .env.local for local development.

# Frontend -> backend API base URL
NEXT_PUBLIC_BACKEND_URL="http://localhost:3001"

# Database URL (temporary bridge via packages/db)
DATABASE_URL="postgresql://user@localhost:5432/postgres?schema=public"

# Backend external providers
GOOGLE_API_KEY="your-google-ai-api-key"
FMP_API_KEY="your-fmp-api-key"
FMP_BASE_URL="https://financialmodelingprep.com/api/v3"

# Note:
# NextAuth-specific variables were removed in Module 1.
# Backend-owned auth/session variables will be added in Module 3 auth implementation.
