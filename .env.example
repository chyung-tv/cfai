# CFAI - VPS Deployment Environment Variables
# Copy to .env and fill in values

# ============================================
# DATABASE (Docker Compose Postgres)
# ============================================
POSTGRES_USER=cfai
POSTGRES_PASSWORD=changeme_change_in_production
POSTGRES_DB=cfai

# Prisma / App connection string (used by both web and backend)
DATABASE_URL="postgresql://cfai:changeme_change_in_production@localhost:5432/cfai"

# ============================================
# REDIS (Docker Compose)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# BACKEND API KEY (shared secret - Next.js calls backend with this)
# Generate: openssl rand -hex 32
# ============================================
BACKEND_API_KEY=

# ============================================
# AI & EXTERNAL APIS
# ============================================
GOOGLE_API_KEY=
FMP_API_KEY=
FMP_BASE_URL="https://financialmodelingprep.com/api/v3"

# ============================================
# NEXT.JS / NEXTAUTH (Web app)
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=  # openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# INTERNAL (Docker Compose - override for local dev)
# ============================================
# Backend URL - web uses this to call backend (server-side only)
BACKEND_URL="http://localhost:3001"
