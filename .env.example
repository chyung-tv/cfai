# CFAI environment template (Module 2 Docker-first baseline)
# Copy to `.env` for docker compose, or `.env.local` for host-side local commands.

# Frontend -> backend API URL used by browser clients
NEXT_PUBLIC_BACKEND_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# PostgreSQL (docker compose defaults)
POSTGRES_DB="cfai"
POSTGRES_USER="cfai"
POSTGRES_PASSWORD="cfai"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"

# Backend database URL (async SQLAlchemy + Alembic)
DATABASE_URL="postgresql+asyncpg://cfai:cfai@localhost:5432/cfai"

# Backend external providers
GOOGLE_API_KEY="your-google-ai-api-key"
FMP_API_KEY="your-fmp-api-key"
FMP_BASE_URL="https://financialmodelingprep.com/api/v3"

# Backend auth/session (Module 3.1)
GOOGLE_OAUTH_CLIENT_ID="your-google-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="your-google-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3001/auth/oauth/google/callback"
SESSION_COOKIE_NAME="cfai_session"
SESSION_COOKIE_SECURE="false"
SESSION_TTL_SECONDS="604800"
PASSWORD_RESET_TTL_SECONDS="1800"

# Notes:
# - In docker compose, backend uses the postgres service hostname internally.
# - Alembic migrations are manual by policy (see README commands).
