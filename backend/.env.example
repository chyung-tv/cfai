# Backend runtime environment (template)

# External services only.
# App/runtime defaults are configured in `backend/app/core/defaults.py`.

# Database (Neon)
DATABASE_URL="postgresql+asyncpg://<user>:<password>@<pooled-host>/<db>?sslmode=require&channel_binding=require"
DATABASE_URL_DIRECT="postgresql+asyncpg://<user>:<password>@<direct-host>/<db>?sslmode=require&channel_binding=require"

# Google / Vertex AI
VERTEX_AI_PROJECT_ID="your-gcp-project-id"
VERTEX_AI_API_KEY="your-vertex-ai-api-key"
VERTEX_AI_LOCATION="global"

# Financial Modeling Prep
FMP_API_KEY="your-fmp-api-key"

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID="your-google-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="your-google-client-secret"

# Copilot memory pipeline (optional overrides)
MEMORY_DEFAULT_USER_ID="local-user"
MEMORY_RECALL_MAX_CANDIDATES=40
MEMORY_PROMPT_TOPK=8
MEMORY_SUMMARY_MAX_CHARS=900
MEMORY_WRITE_CONFIDENCE_THRESHOLD=0.8
MEMORY_JOB_MAX_RETRIES=2
MEMORY_COMPRESSION_MIN_WRITES=8
MEMORY_COMPRESSION_INJECTED_CHAR_LIMIT=1000
MEMORY_COMPRESSION_MAX_SUMMARY_AGE_HOURS=24
MEMORY_COMPRESSION_COOLDOWN_MINUTES=10
TURN_STRUCTURED_OUTPUT_ENABLED=true
TURN_SCHEMA_RETRY_MAX=3
TURN_SCHEMA_REPAIR_ENABLED=true
MEMORY_SUGGESTION_FALLBACK_MODE="rule_based"
MEMORY_SUGGESTION_MAX_CANDIDATES=6
